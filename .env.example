# Supabase project credentials (safe to use client-side — these are the anon/public keys)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# OpenAI key is NOT set here — it lives as a Supabase Edge Function secret.
# Set it with: supabase secrets set OPENAI_API_KEY=sk-...
# Or via Supabase Dashboard → Project Settings → Edge Functions → Secrets
